# Docker-local runtime overrides for docker compose services.
# Keep secrets in the project .env; this file only corrects container-internal hosts.

APP_ENV=local
DB_HOST=mysql
DB_PORT=3306
REDIS_HOST=redis
REDIS_PORT=6379
WORKER_API_BASE_URL=http://nginx
MIGRATION_RECONCILE_INTERVAL_SECONDS=15
LIVE_ENABLED=false
