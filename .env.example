# WorkEddy Environment Configuration
# Copy this file to .env and fill in your values.
# docker compose applies container-specific host overrides from infrastructure/docker/compose.env.

APP_ENV=local

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=workeddy
DB_USER=workeddy
DB_PASS=workeddy
DB_ROOT_PASS=rootsecret

# Queueing
QUEUE_DRIVER=redis
WORKER_QUEUE=scan_jobs

# Redis (used when QUEUE_DRIVER=redis)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Internal worker API
WORKER_API_BASE_URL=http://nginx
WORKER_API_TOKEN=change-me-worker-token
WORKER_API_TIMEOUT_SECONDS=20
WORKER_POLL_INTERVAL_SECONDS=2

# Live worker (separate queue + runtime)
LIVE_ENABLED=false
LIVE_QUEUE_NAME=live_session_jobs
LIVE_POSE_ENGINE=yolo26
LIVE_SCORING_MODEL=reba
LIVE_MULTI_PERSON_MODE=false
LIVE_YOLO_MODEL_VARIANT=yolo26n-pose
LIVE_YOLO_MODEL_FALLBACK_VARIANTS=
LIVE_MEDIAPIPE_MODEL_VARIANT=pose_landmarker_lite
LIVE_TARGET_FPS=5
LIVE_BATCH_WINDOW_MS=500
LIVE_MAX_E2E_LATENCY_MS=2000
LIVE_TEMPORAL_SMOOTHING_ALPHA=0.35
LIVE_MIN_JOINT_CONFIDENCE=0.45
LIVE_TRACKING_MAX_DISTANCE=0.15
LIVE_WORKER_POLL_INTERVAL_SECONDS=1
LIVE_MAX_CONCURRENT_SESSIONS=4
LIVE_MAX_CONCURRENT_SESSIONS_PER_ORG=2
# Optional JSON overrides by plan name. Example: {"starter":1,"professional":4,"enterprise":12}
LIVE_PLAN_CONCURRENCY_LIMITS_JSON=
LIVE_WORKER_COUNT=1
LIVE_SESSION_TIMEOUT_SECONDS=300

# JWT
JWT_SECRET=change-me-in-production
JWT_TTL_SECONDS=3600

# Uploads
MAX_VIDEO_UPLOAD_BYTES=209715200

# Video worker multi-person policy:
#  - dominant_subject: auto-select dominant person when multiple are detected
#  - reject: fail scan if more than one person is detected
VIDEO_MULTI_PERSON_POLICY=dominant_subject

# Rate Limiting
RATE_LIMIT_RPM=120

# Video Data Retention (days before raw video files are deleted; 0 = keep forever)
VIDEO_RETENTION_DAYS=30

# Background cleanup runner interval in seconds (default: every 24h)
VIDEO_CLEANUP_INTERVAL_SECONDS=86400

# Copilot narrative layer
COPILOT_LLM_ENABLED=true
COPILOT_LLM_MODEL=gpt-4.1-mini
COPILOT_LLM_TIMEOUT_MS=6000
COPILOT_API_KEY=SDSDSDSDSD
COPILOT_BASE_URL=https://api.openai.com/v1'

# Copilot audit controls
COPILOT_AUDIT_ENABLED=true
COPILOT_AUDIT_REDACT=true
