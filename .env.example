# WorkEddy Environment Configuration
# Copy this file to .env and fill in your values.

APP_ENV=local

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=workeddy
DB_USER=workeddy
DB_PASS=workeddy
DB_ROOT_PASS=rootsecret

# Queueing
QUEUE_DRIVER=redis
WORKER_QUEUE=scan_jobs

# Redis (used when QUEUE_DRIVER=redis)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Internal worker API
WORKER_API_BASE_URL=http://nginx
WORKER_API_TOKEN=change-me-worker-token
WORKER_API_TIMEOUT_SECONDS=20
WORKER_POLL_INTERVAL_SECONDS=2

# JWT
JWT_SECRET=change-me-in-production
JWT_TTL_SECONDS=3600

# Uploads
MAX_VIDEO_UPLOAD_BYTES=209715200

# Rate Limiting
RATE_LIMIT_RPM=120

# Video Data Retention (days before raw video files are deleted; 0 = keep forever)
VIDEO_RETENTION_DAYS=30
