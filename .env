# WorkEddy Environment Configuration

APP_ENV=production

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=workeddy
DB_USER=workeddy
DB_PASS=workeddy
DB_ROOT_PASS=rootsecret

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
QUEUE_DRIVER=redis
WORKER_QUEUE=scan_jobs

# Internal worker API
WORKER_API_BASE_URL=http://nginx
WORKER_API_TOKEN=change-me-worker-token
WORKER_API_TIMEOUT_SECONDS=20
WORKER_POLL_INTERVAL_SECONDS=2

# JWT
JWT_SECRET=change-me-in-production
JWT_TTL_SECONDS=3600

# Uploads
MAX_VIDEO_UPLOAD_BYTES=209715200
